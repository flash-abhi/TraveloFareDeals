/* ===== GLOBAL RESETS ===== */
.home-new { --primary: #184eb3c2; --primary-light: #2565c9; --primary-dark: #0f3a7d; --accent: #FFFFFF; --accent-dark: #F5F5F5; --success: #10b981; --bg: #f5f5f5; --card: #ffffff; --text: #184eb3c2; --text-muted: #555555; --text-light: #888888; --border: #dddddd; --radius: 8px; --radius-sm: 6px; --shadow: 0 2px 8px rgba(0,0,0,0.1); --shadow-lg: 0 10px 30px rgba(0,0,0,0.12); --shadow-xl: 0 20px 50px rgba(0,0,0,0.15); --transition: all 0.3s cubic-bezier(0.4,0,0.2,1); font-family: 'Poppins', 'Segoe UI', -apple-system, BlinkMacSystemFont, Roboto, sans-serif; }
.home-new *, .home-new *::before, .home-new *::after { box-sizing: border-box; }
.home-new .container { max-width: 1240px; margin: 0 auto; padding: 0 24px; }

/* ===== SCROLL ANIMATIONS ===== */
.scroll-animate { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
.scroll-animate.animate-in { opacity: 1; transform: translateY(0); }

/* ===== HERO SECTION - MAKEMYTRIP STYLE ===== */
.hero-section { 
  position: relative;
  min-height: 700px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 60px 24px;
  animation: heroGradientShift 8s ease-in-out infinite;
}
.hero{
  padding-block: 100px;
}
.overlay{
  height: 100%;
  margin-block: -100px;
  padding-block: 100px;
  background: rgba(0, 0, 0, 0.6);
}
.hero-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1;
}
.search-body{
  padding-block: 20px;
  overflow: visible;
  position: relative;
}


.hero-gradient-overlay { 
  position: absolute; 
  inset: 0; 
  background: transparent;
  animation: overlayPulse 6s ease-in-out infinite;
  display: none;
}

/* Leaf-like particles */
.hero-particles { 
  position: absolute; 
  inset: 0; 
  overflow: hidden; 
  z-index: 2;
  pointer-events: none;
}

.particle { 
  position: absolute; 
  background: rgba(255, 255, 255, 0.05); 
  border-radius: 50%;
  animation: float 15s infinite ease-in-out;
}

.particle-1 { top: 10%; left: 10%; width: 200px; height: 200px; animation-delay: 0s; animation-duration: 20s; }
.particle-2 { top: 60%; right: 15%; width: 150px; height: 150px; animation-delay: 3s; animation-duration: 25s; opacity: 0.3; }
.particle-3 { bottom: 15%; left: 20%; width: 100px; height: 100px; animation-delay: 1s; animation-duration: 22s; }

/* ===== FLIGHTS ANIMATION ===== */
.hero-flights {
  position: absolute;
  inset: 0;
  overflow: hidden;
  z-index: 1;
  pointer-events: none;
}

.flight-plane {
  position: absolute;
  font-size: 56px;
  opacity: 0.5;
  filter: drop-shadow(0 4px 12px rgba(24, 78, 179, 0.4)) drop-shadow(0 0 20px rgba(255, 255, 255, 0.15));
  text-shadow: 0 0 20px rgba(24, 78, 179, 0.6), 0 0 40px rgba(255, 255, 255, 0.2);
}

.flight-plane-1 {
  top: 12%;
  animation: flyAcross 18s ease-in-out infinite, planeWobble 4s ease-in-out infinite;
  animation-delay: 0s;
}

.flight-plane-2 {
  top: 32%;
  animation: flyAcrossReverse 22s ease-in-out infinite, planeBob 3.5s ease-in-out infinite;
  animation-delay: 2s;
}

.flight-plane-3 {
  top: 52%;
  animation: flyAcross 20s ease-in-out infinite, planeSway 5s ease-in-out infinite;
  animation-delay: 4s;
}

.flight-plane-4 {
  top: 72%;
  animation: flyAcrossReverse 24s ease-in-out infinite, planeWobble 4.2s ease-in-out infinite;
  animation-delay: 1s;
}

.flight-plane-5 {
  top: 22%;
  animation: flyAcross 21s ease-in-out infinite, planeBob 3.8s ease-in-out infinite;
  animation-delay: 5s;
}

@keyframes flyAcross {
  0% {
    left: -100px;
    opacity: 0;
    transform: scale(0.7) rotateY(25deg);
  }
  8% {
    opacity: 0.5;
    transform: scale(1) rotateY(0deg);
  }
  92% {
    opacity: 0.5;
    transform: scale(1) rotateY(0deg);
  }
  100% {
    left: calc(100vw + 100px);
    opacity: 0;
    transform: scale(0.7) rotateY(-25deg);
  }
}

@keyframes flyAcrossReverse {
  0% {
    right: -100px;
    opacity: 0;
    transform: scale(0.7) rotateY(-25deg) scaleX(-1);
  }
  8% {
    opacity: 0.5;
    transform: scale(1) rotateY(0deg) scaleX(-1);
  }
  92% {
    opacity: 0.5;
    transform: scale(1) rotateY(0deg) scaleX(-1);
  }
  100% {
    right: calc(100vw + 100px);
    opacity: 0;
    transform: scale(0.7) rotateY(25deg) scaleX(-1);
  }
}

@keyframes planeWobble {
  0%, 100% {
    transform: translateY(0px);
  }
  25% {
    transform: translateY(-12px);
  }
  50% {
    transform: translateY(0px);
  }
  75% {
    transform: translateY(12px);
  }
}

@keyframes planeBob {
  0%, 100% {
    transform: translateY(0px);
  }
  50% {
    transform: translateY(-15px);
  }
}

@keyframes planeSway {
  0%, 100% {
    transform: translateY(0px);
  }
  25% {
    transform: translateY(8px);
  }
  50% {
    transform: translateY(0px);
  }
  75% {
    transform: translateY(-8px);
  }
}

@keyframes float {
  0%, 100% { transform: translateY(0) translateX(0); opacity: 0.05; }
  50% { transform: translateY(-30px) translateX(20px); opacity: 0.15; }
}

@keyframes heroGradientShift {
  0%, 100% { background: #301f22; }
  50% { background: #3d2a2d; }
}

@keyframes overlayPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.9; }
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.95);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.hero-inner {
  position: relative;
  z-index: 3;
  max-width: 900px;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 40px;
}

.hero-left {
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: fadeInDown 0.8s ease-out, slideInLeft 1s ease-out 0.2s both;
  width: 100%;
}

@keyframes fadeInDown {
  from { 
    opacity: 0; 
    transform: translateY(-30px);
  }
  to { 
    opacity: 1; 
    transform: translateY(0);
  }
}

@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-50px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255, 255, 255, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.4);
  padding: 10px 20px;
  border-radius: 25px;
  font-size: 12px;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 16px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.hero-badge:hover {
  background: rgba(255, 255, 255, 0.3);
  transform: translateY(-3px);
}

.hero-title {
  font-size: 48px;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 12px;
  letter-spacing: -0.5px;
}

.hero-highlight {
  color: #FFFFFF;
  display: block;
}

/* ===== FEATURE CARDS ===== */
.hero-features {
  display: none;
}

.feature-card {
  display: flex;
  gap: 14px;
  padding: 18px;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(15px);
  border: 1.5px solid rgba(255, 255, 255, 0.15);
  border-radius: 14px;
  transition: all 0.3s ease;
}

.feature-card:hover {
  background: rgba(255, 255, 255, 0.12);
  border-color: rgba(255, 255, 255, 0.3);
  transform: translateY(-4px);
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2);
}
.icon{
  margin-top: 10px;
}
.feature-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  background: linear-gradient(135deg, #184eb3c2 0%, #2565c9 100%);
  border-radius: 12px;
  flex-shrink: 0;
  color: #fff;
  box-shadow: 0 8px 20px rgba(24, 78, 179, 0.3);
}

.feature-content h4 {
  font-size: 14px;
  font-weight: 800;
  color: #fff;
  margin: 0 0 6px;
  letter-spacing: -0.02em;
}

.feature-content p {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.85);
  margin: 0;
  line-height: 1.5;
  font-weight: 400;
}

.hero-subtitle {
  font-size: 16px;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.95);
  /* margin: 20px 0 28px; */
  max-width: 600px;
  font-weight: 400;
  animation: fadeInUp 0.8s ease-out 0.4s both;
}

.hero-cta-row {
  display: flex;
  gap: 20px;
  justify-content: center;
  flex-wrap: wrap;
  animation: fadeInUp 0.8s ease-out 0.5s both;
}

.hero-phone-btn {
  display: flex;
  align-items: center;
  gap: 16px;
  background: #FFFFFF;
  color: #184eb3c2;
  padding: 14px 28px;
  border-radius: 8px;
  text-decoration: none;
  font-weight: 600;
  transition: var(--transition);
  box-shadow: 0 4px 15px rgba(255, 255, 255, 0.4);
}

.hero-phone-btn:hover {
  background: #F5F5F5;
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(255, 255, 255, 0.6);
}

.hero-phone-btn div {
  display: flex;
  flex-direction: column;
}

.phone-label {
  font-size: 12px;
  opacity: 0.9;
  font-weight: 600;
}

.phone-num {
  font-size: 17px;
  font-weight: 900;
}
.hero-phone-btn div { display: flex; flex-direction: column; }
.phone-label { font-size: 12px; opacity: 0.85; }
.phone-num { font-size: 17px; font-weight: 700; }

.hero-right {
  width: 100%;
  animation: fadeInUp 0.8s ease-out 0.6s both, scaleIn 0.8s ease-out 0.6s both;
}

/* ===== SEARCH WIDGET ===== */
.search-widget {
  background: white;
  border-radius: 16px;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  width: 100%;
  max-width: 1200px;
  overflow: visible;
  position: relative;
  margin: 0 auto;
  border: 1px solid #e5e7eb;
  padding: 18px;
  animation: widgetGlow 3s ease-in-out infinite;
}

@keyframes widgetGlow {
  0%, 100% { box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15); }
  50% { box-shadow: 0 8px 40px rgba(24, 78, 179, 0.25); }
}

.search-tabs {
  display: flex;
  gap: 8px;
  background: transparent;
  border-bottom: 1px solid #e5e7eb;
  padding-bottom: 16px;
  margin-bottom: 24px;
  overflow: visible;
}

.search-tab {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 16px;
  background: transparent;
  border: none;
  cursor: pointer;
  border-radius: 8px;
  font-weight: 600;
  font-size: 14px;
  color: #6b7280;
  transition: all 0.3s;
  position: relative;
}

.search-tab svg {
  color: #184eb3c2;
  stroke-width: 2.5;
}

.search-tab:hover {
  background: rgba(24, 78, 179, 0.08);
  color: #184eb3c2;
}

.search-tab.active {
  background: transparent;
  color: #184eb3c2;
  box-shadow: none;
  border-bottom: 3px solid #184eb3c2;
  padding-bottom: 5px;
}

.search-tab.active svg {
  color: #184eb3c2;
}

/* Trip type toggle */
.trip-toggle {
  display: flex;
  gap: 16px;
  margin-bottom: 24px;
  padding-bottom: 16px;
  border-bottom: none;
}

.trip-toggle button {
  padding: 8px 16px;
  border: none;
  background: transparent;
  border-radius: 8px;
  font-weight: 700;
  color: #6b7280;
  cursor: pointer;
  transition: all 0.3s;
  font-size: 14px;
  position: relative;
}

.trip-toggle button:hover {
  background: rgba(24, 78, 179, 0.08);
  color: #184eb3c2;
}

.trip-toggle button.active {
  background: transparent;
  color: #184eb3c2;
  border: none;
  border-bottom: 3px solid #184eb3c2;
  padding-bottom: 5px;
}

/* Search grid */
.search-grid {
  display: flex;
  flex-wrap: wrap;
  /* grid-template-columns: ; */
  gap: 16px;
  margin-bottom: 16px;
}

.flights-grid {
  grid-template-columns: 1.2fr 50px 1.2fr 1fr 1fr 1fr 1fr;
}

.search-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.search-field label {
  font-size: 12px;
  font-weight: 700;
  color: #374151;
  text-transform: uppercase;
  letter-spacing: 0.3px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.search-field label svg {
  color: #184eb3c2;
  stroke-width: 2.5;
  width: 16px;
  height: 16px;
}

.search-field input,
.search-field select {
  padding: 12px 14px 12px 44px;
  border: 1.5px solid #e5e7eb;
  border-radius: 8px;
  font-size: 14px;
  font-family: inherit;
  transition: all 0.3s;
  background: #f9fafb;
  color: #1a1a1a;
  font-weight: 500;
  position: relative;
  height: 44px;
  width: 100%;
}

.search-field input::placeholder {
  color: #9ca3af;
  font-size: 13px;
}

.search-field input:focus,
.search-field select:focus {
  outline: none;
  border-color: #184eb3c2;
  background: white;
  box-shadow: 0 0 0 3px rgba(24, 78, 179, 0.08);
}

.search-field select option {
  background: #fff;
  color: #1a1a1a;
}

.search-field input,
.search-field select {
  padding-left: 44px;
}

.search-field {
  position: relative;
}

.search-field svg {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: #184eb3c2;
  pointer-events: none;
  z-index: 1;
  stroke-width: 2.5;
  width: 18px;
  height: 18px;
  flex-shrink: 0;
}

.travelers-trigger {
  cursor: pointer;
  text-align: left;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 12px 14px 12px 44px;
  border: 1.5px solid #e5e7eb;
  border-radius: 8px;
  font-size: 14px;
  font-family: inherit;
  background: #f9fafb;
  color: #1a1a1a;
  font-weight: 500;
  transition: all 0.3s ease;
  height: 44px;
  width: 100%;
  position: relative;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
}

.travelers-trigger::before {
  content: '';
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: #184eb3c2;
  pointer-events: none;
  z-index: 1;
  stroke-width: 2.5;
  width: 18px;
  height: 18px;
}

.travelers-field {
  position: relative;
}

.travelers-field svg {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: #184eb3c2;
  pointer-events: none;
  z-index: 1;
  stroke-width: 2.5;
  width: 18px;
  height: 18px;
  display: none;
}

.travelers-trigger:hover {
  background: #f0f0f0;
  border-color: #184eb3c2;
}

.travelers-trigger:active,
.travelers-field:has(.travelers-dropdown) .travelers-trigger {
  background: white;
  border-color: #184eb3c2;
  box-shadow: 0 0 0 3px rgba(24, 78, 179, 0.08);
}

.swap-btn {
  width: 48px;
  height: 48px;
  border-radius: 8px;
  border: none;
  background: #184eb3c2;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  transition: all 0.3s ease;
  align-self: flex-end;
  margin-bottom: 0;
  font-weight: 700;
  flex-shrink: 0;
}

.swap-btn svg {
  width: 20px;
  height: 20px;
  stroke-width: 2.5;
}

.swap-btn:hover {
  background: #184eb3c2;
  color: #FFFFFF;
  transform: rotate(180deg);
  box-shadow: 0 4px 12px rgba(24, 78, 179, 0.3);
}

/* Travelers dropdown backdrop overlay */
.travelers-field:has(.travelers-dropdown)::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1100;
  animation: fadeIn 0.2s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* Travelers dropdown */
.travelers-dropdown {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: #fff;
  backdrop-filter: blur(30px);
  border: 1.5px solid #e5e7eb;
  border-radius: 12px;
  padding: 24px;
  z-index: 1200;
  width: 90%;
  max-width: 350px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
  animation: slideDown 0.2s ease-out;
  max-height: 80vh;
  overflow-y: auto;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translate(-50%, -55%);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%);
  }
}

.traveler-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 0;
  border-bottom: 1px solid #e5e7eb;
}

.traveler-row:last-of-type {
  border-bottom: none;
}

.inc-num {
  color: #111827;
  font-weight: 700;
}

.traveler-label {
  font-size: 15px;
  font-weight: 700;
  color: #111827;
  display: block;
}

.traveler-sub {
  font-size: 12px;
  color: #6b7280;
}

.counter {
  display: flex;
  align-items: center;
  gap: 14px;
}

.counter button {
  width: 28px;
  height: 28px;
  border-radius: 8px;
  border: 1.5px solid #e5e7eb;
  background: #f9fafb;
  cursor: pointer;
  font-size: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #184eb3c2;
  transition: all 0.3s ease;
  font-weight: 600;
}

.counter button:hover {
  border-color: #184eb3c2;
  background: #f0f4ff;
}

.counter span {
  font-size: 16px;
  font-weight: 700;
  min-width: 24px;
  text-align: center;
  color: #111827;
}

.cabin-select {
  margin-top: 14px;
  padding-top: 14px;
  border-top: 1px solid #e5e7eb;
}

.cabin-select label {
  font-size: 12px;
  font-weight: 700;
  color: #6b7280;
  margin-bottom: 8px;
  display: block;
  text-transform: uppercase;
}

.cabin-select select {
  width: 100%;
  padding: 11px 14px;
  border: 1.5px solid #e5e7eb;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 500;
  background: #fff;
  color: #111827;
}

.cabin-select select option {
  background: #fff;
  color: #111827;
}

.done-btn {
  width: 100%;
  padding: 12px;
  margin-top: 14px;
  background: linear-gradient(135deg, #184eb3c2 0%, #2565c9 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 10px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.3s ease;
}

.done-btn:hover {
  background: linear-gradient(135deg, #2565c9 0%, #184eb3c2 100%);
  transform: translateY(-1px);
}

.search-bottom {
  display: flex;
  gap: 16px;
  align-items: center;
  margin-bottom: 0;
}

.search-passengers {
  flex: 1;
  position: relative;
}

.search-passengers label {
  display: block;
  font-size: 12px;
  font-weight: 700;
  color: #6b7280;
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.search-passengers button {
  width: 100%;
  padding: 14px 16px;
  border: 1.5px solid #e5e7eb;
  background: #fff;
  color: #111827;
  font-size: 15px;
  border-radius: 12px;
  transition: all 0.3s ease;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-weight: 500;
}

.search-passengers button:hover {
  background: #f0f4ff;
  border-color: #184eb3c2;
}

.search-passengers button:focus {
  outline: none;
  border-color: #184eb3c2;
  box-shadow: 0 0 0 3px rgba(24, 78, 179, 0.15);
}

/* Search button */
.search-btn {
  background: var(--primary);
  color: white;
  border: none;
  padding: 14px 28px;
  border-radius: 6px;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  /* transition: var(--transition); */
  text-transform: uppercase;
  letter-spacing: 0.3px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  box-shadow: 0 4px 12px rgba(78, 70, 72, 0.3);
}

.search-btn::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.5) 0%, transparent 70%);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  transition: width 0.6s ease, height 0.6s ease;
}

.search-btn:hover::before {
  width: 300px;
  height: 300px;
}

.search-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
  transition: left 0.5s ease;
}

.search-button{
  display: flex;
  margin-inline: auto;
  width: 100%;
  justify-content: center;
  align-items: center;
  padding: 14px 28px;
  border-radius: 8px;
  background-color: #184eb3c2;
  /* border: none; */
  color: var(--accent);
  border-color: var(--primary);
  gap: 4px;
  cursor: pointer;
  font-size: 20px;
}
.search-button:hover{
  background: #2565c9;
  border: 2px solid #111827;
  color: #fff;
}

.search-btn:hover {
  background: var(--primary-dark);
  box-shadow: 0 6px 20px rgba(31, 59, 240, 0.658);
  transform: translateY(-2px);
}

.search-btn:active {
  transform: translateY(0);
}


/* ===== SERVICES STRIP ===== */
.services-strip { background: #fff; border-bottom: 1px solid var(--border); padding: 20px 0; }
.services-row { display: flex; justify-content: center; flex-wrap: wrap; gap: 12px; }
.service-pill { display: flex; align-items: center; gap: 8px; padding: 10px 20px; background: var(--bg); border-radius: 50px; font-size: 14px; font-weight: 600; color: var(--text); border: 1px solid var(--border); transition: var(--transition); }
.service-pill:hover { border-color: var(--primary); color: var(--primary); background: rgba(79,70,229,0.04); }
.service-pill svg { color: var(--primary); }

/* ===== CALL BANNER ===== */
.call-banner { padding: 32px 0; background: var(--bg); }
.call-banner-inner { display: flex; align-items: center; justify-content: space-between; background: linear-gradient(135deg, #184eb3c2, #2565c9); border-radius: var(--radius); padding: 32px 40px; color: #fff; }
.call-banner-left { display: flex; align-items: center; gap: 20px; }
.call-banner-icon { width: 64px; height: 64px; background: rgba(255,255,255,0.15); border-radius: 16px; display: flex; align-items: center; justify-content: center; }
.call-banner-left h3 { font-size: 22px; margin: 0 0 4px; }
.call-banner-left p { margin: 0; opacity: 0.85; font-size: 15px; }
.call-banner-btn { display: flex; align-items: center; gap: 12px; background: #fff; color: var(--text); padding: 14px 28px; border-radius: 14px; text-decoration: none; font-weight: 600; transition: var(--transition); box-shadow: 0 4px 20px rgba(0,0,0,0.15); }
.call-banner-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(0,0,0,0.2); }
.banner-phone { font-size: 20px; font-weight: 800; display: block; color: var(--primary); }
.banner-avail { font-size: 12px; color: var(--text-muted); }

/* ===== SECTION HEADERS ===== */
.section-head { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 40px; }
.section-head.centered { flex-direction: column; align-items: center; text-align: center; }
.section-head h2 { font-size: 34px; font-weight: 800; color: var(--text); margin: 0 0 8px; letter-spacing: -0.02em; }
.section-head p { font-size: 16px; color: var(--text-muted); margin: 0; }
.see-all-btn { display: flex; align-items: center; gap: 8px; padding: 10px 20px; background: rgba(79,70,229,0.08); color: var(--primary); border: none; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; transition: var(--transition); white-space: nowrap; }
.see-all-btn:hover { background: var(--primary); color: #fff; }

/* ===== POPULAR ROUTES ===== */
.popular-routes-section { padding: 72px 0; background: #fff; }
.routes-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.route-grid { display: none; }

/* ===== NEW ROUTES DESIGN - CLEAN & PROFESSIONAL ===== */
.routes-grid-new { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }

.route-card-modern { 
  background: #ffffff; 
  border-radius: 12px; 
  padding: 24px; 
  cursor: pointer; 
  transition: all 0.3s ease; 
  border: 1px solid #e5e7eb;
  border-left: 4px solid #184eb3c2;
  position: relative; 
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.route-card-modern:hover { 
  transform: translateY(-6px); 
  box-shadow: 0 12px 32px rgba(24, 78, 179, 0.12);
  border-left-color: #184eb3c2;
}

.route-tag { 
  display: none;
}

.route-content { 
  padding: 0; 
  display: flex; 
  flex-direction: column; 
  gap: 18px; 
}

.route-header { 
  display: flex; 
  align-items: center; 
  justify-content: space-between; 
  gap: 12px;
}

.route-from, .route-to { 
  font-size: 16px; 
  font-weight: 700; 
  color: #1a1a1a; 
  line-height: 1.3;
}

.route-code { 
  font-size: 11px; 
  color: #9ca3af; 
  font-weight: 500; 
  margin-top: 2px; 
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.route-duration { 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  flex-shrink: 0;
  color: #9ca3af;
}

.route-footer { 
  display: flex; 
  align-items: center; 
  justify-content: space-between; 
  gap: 12px;
  padding-top: 0;
  border-top: none;
}

.airline-tag { 
  font-size: 11px; 
  color: #6b7280; 
  font-weight: 500; 
  background: transparent; 
  padding: 0; 
  border-radius: 0;
  text-transform: capitalize;
}

.price-tag { 
  font-size: 18px; 
  font-weight: 800; 
  color: #184eb3c2;
}

/* ===== DEALS SHOWCASE ===== */
.deals-showcase { padding: 72px 0; background: linear-gradient(180deg, #ffffff 0%, #f9fafb 100%); }
.showcase-header { text-align: center; margin-bottom: 56px; }
.showcase-header h2 { font-size: 40px; font-weight: 800; color: #1a1a1a; margin: 0 0 12px; }
.showcase-header p { font-size: 18px; color: #6b7280; margin: 0; }
.deals-showcase-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; }
.deal-showcase-card { background: #ffffff; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08); transition: all 0.3s ease; }
.deal-showcase-card:hover { transform: translateY(-12px); box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12); }
.deal-showcase-img { position: relative; height: 280px; overflow: hidden; }
.deal-showcase-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
.deal-showcase-card:hover .deal-showcase-img img { transform: scale(1.1); }
.deal-overlay-new { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(24, 78, 179, 0.7) 0%, rgba(26, 26, 26, 0.3) 100%); display: flex; align-items: flex-start; justify-content: flex-end; padding: 16px; opacity: 0; transition: opacity 0.3s ease; }
.deal-showcase-card:hover .deal-overlay-new { opacity: 1; }
.deal-badge-new { background: #FFFFFF; color: #184eb3c2; padding: 10px 16px; border-radius: 12px; font-weight: 700; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; }
.deal-showcase-content { padding: 28px 24px; }
.deal-showcase-content h3 { font-size: 24px; font-weight: 700; color: #1a1a1a; margin: 0 0 8px; }
.deal-tagline { font-size: 14px; color: #184eb3c2; margin: 0 0 16px; font-style: italic; }
.deal-rating-new { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
.stars { display: flex; gap: 4px; }
.review-count { font-size: 13px; color: #6b7280; }
.price-comparison { display: flex; align-items: center; gap: 12px; padding-top: 16px; border-top: 1px solid #e5e7eb; }
.original-price { text-decoration: line-through; color: #9ca3af; font-size: 16px; }
.current-price { font-size: 28px; font-weight: 800; color: #184eb3c2; }
.discount { background: linear-gradient(135deg, #184eb3c2, #2565c9); color: #ffffff; padding: 6px 12px; border-radius: 8px; font-weight: 700; font-size: 12px; }

/* ===== RESPONSIVE ===== */
@media (max-width: 1200px) {
  .routes-grid-new { grid-template-columns: repeat(2, 1fr); gap: 18px; }
  .deals-showcase-grid { grid-template-columns: 1fr; }
}

@media (max-width: 768px) {
  .routes-grid-new { grid-template-columns: 1fr; gap: 16px; }
  .route-card-modern { padding: 20px; gap: 16px; }
  .route-from, .route-to { font-size: 15px; }
  .price-tag { font-size: 16px; }
  .deals-showcase-grid { grid-template-columns: 1fr; gap: 24px; }
}

@media (max-width: 480px) {
  .route-card-modern { padding: 16px; gap: 14px; }
  .route-from, .route-to { font-size: 14px; }
  .route-header { gap: 8px; }
  .price-tag { font-size: 15px; }
}
.route-card { border-radius: var(--radius); overflow: hidden; background: #fff; border: 1px solid var(--border); cursor: pointer; transition: var(--transition); }
.route-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: transparent; }
.route-img { position: relative; height: 160px; overflow: hidden; }
.route-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
.route-card:hover .route-img img { transform: scale(1.08); }
.route-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.2); display: flex; align-items: center; justify-content: center; opacity: 0; transition: var(--transition); color: #fff; }
.route-card:hover .route-overlay { opacity: 1; }
.route-info { padding: 16px; }
.route-path { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
.route-city { font-size: 15px; font-weight: 700; color: var(--text); }
.route-arrow { color: var(--primary); display: flex; }
.route-meta { display: flex; align-items: center; justify-content: space-between; }
.route-airline { font-size: 12px; color: var(--text-light); }
.route-price { font-size: 14px; color: var(--text-muted); }
.route-price strong { color: var(--primary); font-size: 18px; font-weight: 800; }

/* ===== EXCLUSIVE DEALS ===== */
.deals-section { padding: 72px 0; background: var(--bg); }
.deals-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
.deal-card { background: #fff; border-radius: var(--radius); overflow: hidden; cursor: pointer; transition: var(--transition); border: 1px solid var(--border); }
.deal-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); border-color: transparent; }
.deal-image { position: relative; height: 200px; overflow: hidden; }
.deal-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s; }
.deal-card:hover .deal-image img { transform: scale(1.08); }
.deal-badge { position: absolute; top: 14px; left: 14px; padding: 6px 14px; background: var(--primary); color: #fff; font-size: 12px; font-weight: 700; border-radius: 8px; text-transform: uppercase; letter-spacing: 0.03em; }
.deal-save { position: absolute; top: 14px; right: 14px; padding: 6px 12px; background: rgba(239,68,68,0.9); color: #fff; font-size: 12px; font-weight: 700; border-radius: 8px; }
.deal-body { padding: 20px; }
.deal-tagline { font-size: 12px; font-weight: 600; color: var(--primary); text-transform: uppercase; letter-spacing: 0.05em; }
.deal-destination { font-size: 20px; font-weight: 700; color: var(--text); margin: 6px 0 10px; }
.deal-rating { display: flex; align-items: center; gap: 6px; margin-bottom: 14px; font-size: 14px; font-weight: 600; color: var(--text); }
.deal-reviews { font-weight: 400; color: var(--text-light); font-size: 12px; }
.deal-pricing { display: flex; align-items: baseline; gap: 8px; margin-bottom: 16px; }
.deal-original { text-decoration: line-through; color: var(--text-light); font-size: 14px; }
.deal-price { font-size: 28px; font-weight: 800; color: var(--accent); }
.deal-per { font-size: 12px; color: var(--text-muted); }
.deal-btn { width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 12px; background: var(--primary); color: #fff; border: none; border-radius: var(--radius-sm); font-size: 14px; font-weight: 700; cursor: pointer; transition: var(--transition); }
.deal-btn:hover { background: var(--primary-dark); }

/* ===== STATS SECTION ===== */
.stats-section { padding: 72px 0; background: linear-gradient(135deg, var(--primary-dark), var(--primary)); }
.stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; }
.stat-card { text-align: center; display: flex; flex-direction: column; color: #fff; padding: 32px 20px; }
.stat-icon-wrap { width: 44px; padding-top: 30px; height: 44px; background: #fff; border-radius: 18px; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; }
.stat-card h3 { font-size: 36px; font-weight: 800; margin: 0 0 8px; }
.stat-card p { font-size: 15px; opacity: 0.85; margin: 0; font-weight: 500; }

/* ===== WHY CHOOSE US ===== */
.why-section { padding: 72px 0; background: #fff; }
.why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
.why-card { padding: 32px; border-radius: var(--radius); border: 1px solid var(--border); transition: var(--transition); background: #fff; }
.why-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: transparent; }
.why-icon { width: 56px; height: 56px; border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; }
.why-card h3 { font-size: 18px; font-weight: 700; color: var(--text); margin: 0 0 10px; }
.why-card p { font-size: 14px; color: var(--text-muted); line-height: 1.7; margin: 0; }

/* ===== TESTIMONIALS ===== */
.testimonials-section { padding: 72px 0; background: var(--bg); }
.testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
.testimonial-card { background: #fff; padding: 32px; border-radius: var(--radius); border: 1px solid var(--border); transition: var(--transition); }
.testimonial-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: transparent; }
.testimonial-stars { display: flex; gap: 4px; margin-bottom: 16px; }
.testimonial-text { font-size: 15px; line-height: 1.7; color: var(--text); margin: 0 0 20px; font-style: italic; }
.testimonial-author { display: flex; align-items: center; gap: 12px; }
.author-avatar { width: 48px; height: 48px; background: var(--bg); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; }
.testimonial-author strong { display: block; font-size: 15px; color: var(--text); }
.testimonial-author span { font-size: 13px; color: var(--text-muted); }

/* ===== NEWSLETTER ===== */
.newsletter-section { padding: 72px 0; background: #fff; }
.newsletter-inner { background: linear-gradient(135deg, var(--primary-dark), var(--primary)); border-radius: 24px; padding: 56px 48px; display: flex; align-items: center; justify-content: space-between; gap: 40px; color: #fff; }
.newsletter-text h2 { font-size: 28px; font-weight: 800; margin: 0 0 10px; }
.newsletter-text p { font-size: 15px; opacity: 0.85; margin: 0; max-width: 400px; }
.newsletter-form { display: flex; gap: 12px; flex-shrink: 0; }
.newsletter-input-wrap { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.25); border-radius: 12px; padding: 14px 18px; min-width: 300px; }
.newsletter-input-wrap svg { color: rgba(255,255,255,0.6); flex-shrink: 0; }
.newsletter-input-wrap input { border: none; background: transparent; color: #fff; font-size: 15px; width: 100%; outline: none; }
.newsletter-input-wrap input::placeholder { color: rgba(255,255,255,0.5); }
.newsletter-btn { display: flex; align-items: center; gap: 8px; padding: 14px 28px; background: #fff; color: var(--primary); border: none; border-radius: 12px; font-size: 15px; font-weight: 700; cursor: pointer; transition: var(--transition); white-space: nowrap; }
.newsletter-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.2); }

/* ===== BOTTOM CTA ===== */
.bottom-cta { padding: 72px 0; background: var(--bg); }
.bottom-cta-inner { text-align: center; padding: 56px 40px; background: linear-gradient(135deg, #1a1a1a, #2d2d2d); border-radius: 24px; color: #fff; }
.bottom-cta-inner h2 { font-size: 34px; font-weight: 800; margin: 0 0 12px; }
.bottom-cta-inner p { font-size: 16px; opacity: 0.8; margin: 0 0 32px; }
.bottom-cta-actions { display: flex; align-items: center; justify-content: center; gap: 16px; }
.cta-primary { display: flex; align-items: center; gap: 10px; padding: 16px 32px; background: linear-gradient(135deg, #184eb3c2, #2565c9); color: #fff; border-radius: 14px; text-decoration: none; font-size: 18px; font-weight: 700; transition: var(--transition); box-shadow: 0 4px 20px rgba(24, 78, 179, 0.3); }
.cta-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(24, 78, 179, 0.4); }
.cta-secondary { display: flex; align-items: center; gap: 10px; padding: 16px 32px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: #fff; border-radius: 14px; text-decoration: none; font-size: 16px; font-weight: 600; transition: var(--transition); }
.cta-secondary:hover { background: rgba(255,255,255,0.2); }

/* ===== RESPONSIVE ===== */
@media (max-width: 1400px) {
  .search-grid {
    grid-template-columns: 1.5fr 50px 1.5fr 1.2fr 1.2fr 1fr;
    gap: 14px;
  }

  .search-field label {
    font-size: 12px;
  }

  .search-field label svg {
    width: 15px;
    height: 15px;
  }

  .search-field input,
  .search-field select,
  .travelers-trigger {
    font-size: 13px;
    padding: 10px 12px 10px 40px;
    height: 40px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .search-field svg,
  .travelers-field svg {
    left: 10px;
    width: 16px;
    height: 16px;
  }

  .swap-btn {
    width: 44px;
    height: 44px;
  }

  .swap-btn svg {
    width: 18px;
    height: 18px;
  }
}

@media (max-width: 1200px) {
  .hero-section {
    min-height: 750px;
    padding: 60px 24px;
  }

  .hero-inner {
    gap: 50px;
    padding: 80px 24px;
  }

  .hero-title {
    font-size: 56px;
  }

  .hero-subtitle {
    font-size: 16px;
  }

  .hero-features {
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
    margin: 24px 0 24px;
  }

  .feature-card {
    gap: 12px;
    padding: 16px;
  }

  .feature-icon {
    width: 42px;
    height: 42px;
  }

  .feature-content h4 {
    font-size: 13px;
  }

  .feature-content p {
    font-size: 11px;
  }

  .search-widget {
    padding: 18px;
  }

  .search-grid {
    grid-template-columns: 1fr 45px 1fr 1fr 1fr;
    gap: 12px;
  }

  .search-field label {
    font-size: 11px;
  }

  .search-field label svg {
    width: 14px;
    height: 14px;
  }

  .search-field input,
  .search-field select,
  .travelers-trigger {
    font-size: 12px;
    padding: 9px 11px 9px 36px;
    height: 38px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .search-field input::placeholder {
    font-size: 12px;
  }

  .search-field svg,
  .travelers-field svg {
    left: 9px;
    width: 15px;
    height: 15px;
  }

  .swap-btn {
    width: 45px !important;
    height: 45px !important;
  }

  .swap-btn svg {
    width: 17px;
    height: 17px;
  }

  .search-bottom {
    gap: 12px;
  }
  
  .deals-grid { grid-template-columns: repeat(2, 1fr); }
  .routes-grid { grid-template-columns: repeat(2, 1fr); }
  .newsletter-inner { flex-direction: column; text-align: center; padding: 40px 32px; }
  .newsletter-text { max-width: 100%; }
  .newsletter-text p { max-width: 100%; }
  .newsletter-form { width: 100%; justify-content: center; }
}

@media (max-width: 1024px) {
  .search-grid {
    grid-template-columns: 1.3fr 45px 1.3fr 1fr 1fr;
    gap: 12px;
  }

  .search-field label {
    font-size: 11px;
  }

  .search-field label svg {
    width: 13px;
    height: 13px;
  }

  .search-field input,
  .search-field select,
  .travelers-trigger {
    font-size: 12px;
    padding: 9px 10px 9px 35px;
    height: 36px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .hero{
  padding: 100px;
}
  .search-field svg,
  .travelers-field svg {
    left: 8px;
    width: 14px;
    height: 14px;
  }

  .swap-btn {
    width: 40px;
    height: 40px;
    margin: 0 auto;
    transform: rotate(90deg);
  }

  .swap-btn svg {
    width: 16px;
    height: 16px;
  }

  .swap-btn:hover {
    transform: rotate(270deg);
  }
}

@media (max-width: 768px) {
  .hero-section {
    min-height: auto;
    padding: 40px 16px;
  }
  .hero{
  padding: 0px;
  padding-block: 20px;
}
  .travelers-field:has(.travelers-dropdown)::before {
    background: rgba(0, 0, 0, 0.6);
  }

  .travelers-dropdown {
    position: fixed;
    top: auto;
    left: 12px;
    right: 12px;
    bottom: 0;
    transform: none;
    width: calc(100% - 24px);
    max-width: 100%;
    border-radius: 16px 16px 0 0;
    padding: 24px 20px;
    max-height: 65vh;
    animation: slideUp 0.3s ease-out;
  }

  .traveler-row {
    padding: 16px 0;
  }

  .traveler-label {
    font-size: 15px;
  }

  .traveler-sub {
    font-size: 12px;
  }

  .counter button {
    width: 32px;
    height: 32px;
    font-size: 18px;
  }

  .counter span {
    font-size: 16px;
    min-width: 30px;
  }

  .counter {
    gap: 16px;
  }

  .done-btn {
    padding: 14px;
    font-size: 15px;
    margin-top: 20px;
  }

  .hero-inner {
    grid-template-columns: 1fr;
    gap: 40px;
    padding: 60px 16px;
  }

  .hero-title {
    font-size: 44px;
    line-height: 1.15;
    margin-bottom: 20px;
  }

  .hero-features {
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin: 20px 0 20px;
  }

  .feature-card {
    gap: 12px;
    padding: 14px;
    flex-direction: column;
    text-align: center;
    align-items: center;
  }

  .feature-icon {
    width: 40px;
    height: 40px;
  }

  .feature-content h4 {
    font-size: 13px;
    margin: 0 0 5px;
  }

  .feature-content p {
    font-size: 11px;
    line-height: 1.4;
  }

  .hero-subtitle {
    font-size: 15px;
    margin: 16px 0 24px;
  }

  .hero-badge {
    padding: 12px 24px;
    font-size: 12px;
  }

  .search-tabs {
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .search-tabs button,
  .search-tab {
    font-size: 12px;
    padding: 10px 12px;
    flex: 0 1 auto;
  }

  .search-grid {
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .search-field label {
    font-size: 11px;
  }

  .search-field label svg {
    width: 14px;
    height: 14px;
  }

  .search-field input,
  .search-field select,
  .travelers-trigger {
    font-size: 13px;
    padding: 10px 12px 10px 38px;
    height: 40px;
    width: 100%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .search-field input::placeholder {
    font-size: 12px;
  }

  .search-field svg,
  .travelers-field svg {
    left: 10px;
    width: 16px;
    height: 16px;
  }

  .swap-btn {
    width: auto;
    height: auto;
    padding: 12px;
    transform: none !important;
    margin: 0 !important;
    width: 100%;
  }

  .swap-btn svg {
    width: 18px;
    height: 18px;
  }

  .swap-btn:hover {
    transform: rotate(180deg);
  }

  .flights-grid { grid-template-columns: 1fr; }
  .flights-grid .swap-btn { margin: 0 !important; }
  .hotels-grid { grid-template-columns: 1fr; }

  .search-widget {
    padding: 10px;
    width: 100% !important;
  }

  .search-bottom {
    flex-direction: column;
    gap: 12px;
  }


  .routes-grid { grid-template-columns: 1fr; }
  .routes-grid-new { grid-template-columns: 1fr; }
  .deals-showcase-grid { grid-template-columns: 1fr; }
  .deals-grid { grid-template-columns: 1fr; }
  .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; }
  .why-grid { grid-template-columns: 1fr; }
  .testimonials-grid { grid-template-columns: 1fr; }
  .section-head { flex-direction: column; align-items: flex-start; gap: 16px; }
  .section-head h2 { font-size: 26px; }
  .call-banner-inner { flex-direction: column; text-align: center; gap: 20px; padding: 24px; }
  .call-banner-left { flex-direction: column; }
  .newsletter-form { flex-direction: column; }
  .newsletter-input-wrap { min-width: auto; width: 100%; }
  .bottom-cta-actions { flex-direction: column; }
  .bottom-cta-inner { padding: 40px 24px; }
  .bottom-cta-inner h2 { font-size: 26px; }
  .services-row { justify-content: flex-start; overflow-x: auto; flex-wrap: nowrap; padding-bottom: 8px; }
  .service-pill { white-space: nowrap; flex-shrink: 0; }

  .particle-1 { width: 80px; height: 80px; }
  .particle-2 { width: 100px; height: 100px; }
  .particle-3 { width: 70px; height: 70px; }
  .particle-4 { width: 90px; height: 90px; }
  .particle-5 { width: 60px; height: 60px; }
  .particle-6 { width: 75px; height: 75px; }
  .particle-7 { width: 85px; height: 85px; }
  .particle-8 { width: 65px; height: 65px; }
}

@media (max-width: 480px) {
  .travelers-field:has(.travelers-dropdown)::before {
    background: rgba(0, 0, 0, 0.7);
  }

  .travelers-dropdown {
    position: fixed;
    top: auto;
    left: 8px;
    right: 8px;
    bottom: 0;
    transform: none;
    width: calc(100% - 16px);
    max-width: 100%;
    border-radius: 20px 20px 0 0;
    padding: 20px 16px;
    max-height: 70vh;
    overflow-y: auto;
    animation: slideUp 0.3s ease-out;
  }

  .traveler-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 0;
    border-bottom: 1px solid #e5e7eb;
  }

  .traveler-label {
    font-size: 16px;
    font-weight: 700;
  }

  .traveler-sub {
    font-size: 13px;
    color: #6b7280;
  }

  .counter {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .counter button {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    font-size: 20px;
  }

  .counter span {
    font-size: 18px;
    font-weight: 700;
    min-width: 32px;
    text-align: center;
  }

  .cabin-select {
    margin-top: 18px;
    padding-top: 18px;
  }

  .cabin-select label {
    font-size: 13px;
    margin-bottom: 10px;
  }

  .cabin-select select {
    padding: 13px 14px;
    font-size: 14px;
    height: 44px;
  }

  .done-btn {
    width: 100%;
    padding: 16px;
    margin-top: 22px;
    font-size: 16px;
    font-weight: 700;
    height: 48px;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(100%);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-inner {
    padding: 40px 12px;
    gap: 30px;
  }

  .hero-title {
    font-size: 36px;
    margin-bottom: 16px;
  }

  .hero-features {
    grid-template-columns: 1fr;
    gap: 12px;
    margin: 16px 0 16px;
  }

  .routes-grid-new { grid-template-columns: 1fr; }
  .deal-showcase-card { border-radius: 16px; }
  .deals-showcase-grid { grid-template-columns: 1fr; }
  .deal-showcase-img { height: 200px; }
  .showcase-header h2 { font-size: 28px; }
  .deal-showcase-content h3 { font-size: 18px; }
  .price-comparison { flex-wrap: wrap; gap: 8px; }

  .feature-card {
    gap: 12px;
    padding: 12px;
    flex-direction: row;
    text-align: left;
    align-items: flex-start;
  }

  .feature-icon {
    width: 40px;
    height: 44px;
    flex-shrink: 0;
    background-color: #fff;
  }

  .feature-content h4 {
    font-size: 12px;
    margin: 2px 0 4px;
  }

  .feature-content p {
    font-size: 10px;
    line-height: 1.3;
  }

  .hero-subtitle {
    font-size: 14px;
    margin: 14px 0 20px;
    line-height: 1.6;
  }

  .hero-badge {
    font-size: 11px;
    padding: 10px 20px;
  }

  .hero-phone-btn {
    width: 100%;
    justify-content: center;
  }

  .search-widget {
    padding: 16px;
  }

  .search-tabs button,
  .search-tab {
    font-size: 11px;
    padding: 8px 8px;
  }

  .trip-toggle button {
    font-size: 11px;
    padding: 8px 10px;
  }

  .search-field label {
    font-size: 10px;
  }

  .search-field label svg {
    width: 12px;
    height: 12px;
  }

  .search-field input,
  .search-field select,
  .search-field button,
  .search-passengers button,
  .travelers-trigger {
    padding: 10px 10px 10px 32px;
    font-size: 12px;
    height: 36px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .search-field svg,
  .travelers-field svg {
    left: 8px;
    width: 13px;
    height: 13px;
  }

  .swap-btn {
    width: 36px;
    height: 36px;
    padding: 6px;
  }

  .swap-btn svg {
    width: 16px;
    height: 16px;
  }

  .search-btn {
    font-size: 14px;
    padding: 14px 24px;
    min-height: 50px;
  }

  /* Responsive travelers dropdown */
  .travelers-field {
    position: relative;
  }

  .travelers-dropdown {
    position: fixed;
    top: auto;
    left: 16px;
    right: 16px;
    bottom: 0;
    transform: none;
    width: calc(100% - 32px);
    max-width: 100%;
    border-radius: 12px 12px 0 0;
    margin: 0;
    max-height: 60vh;
    overflow-y: auto;
    animation: slideUp 0.3s ease-out;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(100%);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .stat-card h3 { font-size: 28px; }
  .deal-price { font-size: 24px; }

  .particle-1 { width: 50px; height: 50px; }
  .particle-2 { width: 60px; height: 60px; }
  .particle-3 { width: 45px; height: 45px; }
  .particle-4 { width: 55px; height: 55px; }
  .particle-5 { width: 40px; height: 40px; }
  .particle-6 { width: 50px; height: 50px; }
  .particle-7 { width: 55px; height: 55px; }
  .particle-8 { width: 45px; height: 45px; }
}

@media (max-width: 360px) {
  .search-widget {
    padding: 12px;
  }

  .travelers-dropdown {
    left: 6px;
    right: 6px;
    width: calc(100% - 12px);
    padding: 16px 14px;
    max-height: 75vh;
  }

  .traveler-row {
    padding: 16px 0;
  }

  .traveler-label {
    font-size: 15px;
  }

  .traveler-sub {
    font-size: 12px;
  }

  .counter button {
    width: 32px;
    height: 32px;
    font-size: 18px;
  }

  .counter span {
    font-size: 16px;
    min-width: 28px;
  }

  .counter {
    gap: 14px;
  }

  .done-btn {
    padding: 13px;
    font-size: 14px;
    margin-top: 18px;
    height: 44px;
  }

  .cabin-select select {
    font-size: 13px;
    padding: 11px 12px;
    height: 40px;
  }

  .search-field label {
    font-size: 9px;
    gap: 4px;
  }

  .search-field label svg {
    width: 11px;
    height: 11px;
  }

  .search-field input,
  .search-field select,
  .travelers-trigger {
    padding: 8px 10px 8px 30px;
    font-size: 11px;
    height: 34px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .search-field input::placeholder {
    font-size: 11px;
  }

  .search-field svg,
  .travelers-field svg {
    left: 7px;
    width: 12px;
    height: 12px;
  }

  .swap-btn {
    width: 32px;
    height: 32px;
    padding: 4px;
  }

  .swap-btn svg {
    width: 14px;
    height: 14px;
  }

  .search-btn {
    font-size: 12px;
    padding: 10px 16px;
    gap: 4px;
  }

  .search-tabs button,
  .search-tab {
    font-size: 10px;
    padding: 6px 6px;
  }

  .trip-toggle button {
    font-size: 10px;
    padding: 6px 8px;
  }

  .hero-title {
    font-size: 28px;
  }

  .hero-subtitle {
    font-size: 12px;
  }
}
